# Copy to keystore.properties (which is gitignored) and fill in.
# Generate a keystore once, then keep it and this file OUT of git.
#
#   keytool -genkey -v -keystore ~/gnubg-release.jks \
#       -keyalg RSA -keysize 2048 -validity 10000 -alias gnubg
#
# storeFile is an absolute path to that .jks; the rest are what you set above.
storeFile=/home/erweitert/gnubg-release.jks
storePassword=CHANGE_ME
keyAlias=gnubg
keyPassword=CHANGE_ME
